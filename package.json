{
  "name": "stitch-luxury-design-digital-showroom",
  "version": "1.0.0",
  "private": true,
  "description": "Trilingual luxury interior & furniture showroom",
  "scripts": {
    "dev:server": "tsx watch src/server/index.ts",
    "dev:frontend": "next dev",
    "dev": "npx concurrently -n server,frontend \"npm run dev:server\" \"node scripts/wait-for-backend.mjs\"",
    "build": "npx prisma generate && next build",
    "vercel-build": "npx prisma generate && next build",
    "start": "next start",
    "seed": "npx tsx prisma/seed.ts",
    "lint": "next lint",
    "typecheck:server": "tsc -p tsconfig.server.json --noEmit",
    "typecheck:frontend": "tsc --noEmit",
    "typecheck": "npm run typecheck:server && npm run typecheck:frontend",
    "test": "jest"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.1.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^1.21.0",
    "morgan": "^1.11.0",
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/cookie-parser": "^1.4.9",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/node": "^25.9.3",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/supertest": "^7.2.0",
    "concurrently": "^9.1.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "jest": "^30.4.2",
    "prisma": "^5.22.0",
    "supertest": "^7.2.2",
    "tailwindcss": "^4",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.0",
    "typescript": "^5"
  }
}
