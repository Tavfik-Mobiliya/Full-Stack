{
  "functions": {
    "api/index.ts": {
      "memory": 256,
      "maxDuration": 10
    }
  },
  "rewrites": [
    {
      "source": "/api/products/:path*",
      "destination": "/api"
    },
    {
      "source": "/api/testimonials/:path*",
      "destination": "/api"
    },
    {
      "source": "/api/inquiries/:path*",
      "destination": "/api"
    },
    {
      "source": "/api/auth/:path*",
      "destination": "/api"
    },
    {
      "source": "/api/collections/:path*",
      "destination": "/api"
    },
    {
      "source": "/api/deals/:path*",
      "destination": "/api"
    },
    {
      "source": "/api/health",
      "destination": "/api"
    }
  ]
}
