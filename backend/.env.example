NODE_ENV=development
PORT=5050
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/stitch_showroom

ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace-with-strong-password
ADMIN_JWT_SECRET=replace-with-at-least-32-characters-secret
AUTH_COOKIE_NAME=showroom_admin_session
AUTH_TOKEN_TTL=15m

CORS_ORIGINS=http://localhost:3000
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
