# PostgreSQL Database URL (use connection pooling for serverless: ?pgbouncer=true)
DATABASE_URL="postgresql://user:password@host:5432/dbname?pgbouncer=true"

# Port (Vercel ignores this, used for local dev)
PORT=5050

# Admin credentials
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=your-secure-password
ADMIN_JWT_SECRET=your-256-bit-hex-secret-at-least-32-chars

# Optional
AUTH_TOKEN_TTL=7d
CORS_ORIGINS=https://your-frontend-domain.vercel.app,http://localhost:3000
